<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context=".DebtTracker">

    <TextView
        android:id="@+id/ActivityTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Activity"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleGroup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="24dp"
        android:orientation="horizontal"
        app:checkedButton="@+id/btnOwesYou"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ActivityTitle"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOwesYou"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Owes You"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/purple" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnYouOwe"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="You Owe"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/purple" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toggleGroup">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/headerOverdue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Overdue"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOverdue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFF5F2"
                app:strokeColor="#FFD3C4"
                app:strokeWidth="1dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgOverdue"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/sym_def_app_icon" />

                    <TextView
                        android:id="@+id/txtNameOverdue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/imgOverdue"
                        android:layout_marginStart="12dp"
                        android:text="Overdue Name"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/txtDetailOverdue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/imgOverdue"
                        android:layout_below="@id/txtNameOverdue"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        android:text="Owes you RM 14.85"
                        android:textColor="@android:color/darker_gray" />

                    <TextView
                        android:id="@+id/txtStatusOverdue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/imgOverdue"
                        android:layout_below="@id/txtDetailOverdue"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        android:text="2 days late"
                        android:textColor="#E53935"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_popup_reminder"
                        android:contentDescription="Bell Reminder Icon" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/txtEmptyOverdue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp"
                android:gravity="center"
                android:text="no one owes you money"
                android:textColor="@android:color/darker_gray"
                android:textSize="15sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/headerPending"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPending"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFBF2"
                app:strokeColor="#FFEEC4"
                app:strokeWidth="1dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgPending"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/sym_def_app_icon" />

                    <TextView
                        android:id="@+id/txtNamePending"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/imgPending"
                        android:layout_marginStart="12dp"
                        android:text="Pending Name"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/txtDetailPending"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/imgPending"
                        android:layout_below="@id/txtNamePending"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        android:text="Owes you RM 14.85"
                        android:textColor="@android:color/darker_gray" />

                    <TextView
                        android:id="@+id/txtStatusPending"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/imgPending"
                        android:layout_below="@id/txtDetailPending"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        android:text="Due tomorrow"
                        android:textColor="#757575" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_popup_reminder"
                        android:contentDescription="Bell Reminder Icon" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/txtEmptyPending"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp"
                android:gravity="center"
                android:text="no pending transactions"
                android:textColor="@android:color/darker_gray"
                android:textSize="15sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/headerPaid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Paid"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOverduePaidCopy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F4FBF4"
                app:strokeColor="#D2ECD2"
                app:strokeWidth="1dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                    <ImageView android:id="@+id/imgOverduePaid" android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/sym_def_app_icon" />
                    <TextView android:id="@+id/txtNameOverduePaid" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/imgOverduePaid" android:layout_marginStart="12dp" android:text="Overdue" android:textStyle="bold" android:textColor="@android:color/black" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/imgOverduePaid" android:layout_below="@id/txtNameOverduePaid" android:layout_marginStart="12dp" android:layout_marginTop="4dp" android:text="Paid RM 14.85" android:textColor="@android:color/darker_gray" />
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@android:drawable/checkbox_on_background" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPendingPaidCopy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F4FBF4"
                app:strokeColor="#D2ECD2"
                app:strokeWidth="1dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                    <ImageView android:id="@+id/imgPendingPaid" android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/sym_def_app_icon" />
                    <TextView android:id="@+id/txtNamePendingPaid" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/imgPendingPaid" android:layout_marginStart="12dp" android:text="Pending" android:textStyle="bold" android:textColor="@android:color/black" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/imgPendingPaid" android:layout_below="@id/txtNamePendingPaid" android:layout_marginStart="12dp" android:layout_marginTop="4dp" android:text="Paid RM 14.85" android:textColor="@android:color/darker_gray" />
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@android:drawable/checkbox_on_background" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPaid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F4FBF4"
                app:strokeColor="#D2ECD2"
                app:strokeWidth="1dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgPaid"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/sym_def_app_icon" />

                    <TextView
                        android:id="@+id/txtNamePaid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/imgPaid"
                        android:layout_marginStart="12dp"
                        android:text="Paid Name"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/txtDetailPaid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/imgPaid"
                        android:layout_below="@id/txtNamePaid"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        android:text="Paid RM 14.85"
                        android:textColor="@android:color/darker_gray" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/imgPaid"
                        android:layout_below="@id/txtDetailPaid"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        android:text="1 day ago"
                        android:textColor="#4CAF50"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/checkbox_on_background"
                        android:contentDescription="Checkmark Status Icon" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>