<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F8F6"
    tools:context=".AddFriends">

    <LinearLayout
        android:id="@+id/headerAdd"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBackAdd"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/baseline_arrow_back_ios_24"
            android:contentDescription="Back"
            app:tint="#1C1B1F"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Add New Friend"
            android:textColor="#1C1B1F"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardFriend"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerAdd"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="#FFFFFF"
        app:strokeWidth="0dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:cardCornerRadius="40dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#F0ECE4">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_report_image"
                        app:tint="#5A189A"/>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Add your friends!"
                    android:textColor="#1C1B1F"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Split bills easier without the awkwardness"
                    android:textColor="#7A757F"
                    android:textSize="13sp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Friend's Name"
                android:textColor="#1C1B1F"
                android:fontFamily="sans-serif-medium"
                android:textSize="14sp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxBackgroundMode="filled"
                app:boxBackgroundColor="#F0ECE4"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:hintEnabled="false"
                app:startIconDrawable="@android:drawable/ic_menu_compass"
                app:startIconTint="#5A189A">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFriendName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="e.g. Alyaa"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:textColor="#1C1B1F"
                    android:textColorHint="#9E9E9E"
                    android:textSize="15sp"
                    android:inputType="textPersonName"
                    android:background="@null"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Phone Number"
                android:textColor="#1C1B1F"
                android:fontFamily="sans-serif-medium"
                android:textSize="14sp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxBackgroundMode="filled"
                app:boxBackgroundColor="#F0ECE4"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:hintEnabled="false"
                app:startIconDrawable="@android:drawable/ic_menu_call"
                app:startIconTint="#5A189A">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFriendPhone"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="e.g. 012-3456789"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:textColor="#1C1B1F"
                    android:textColorHint="#9E9E9E"
                    android:textSize="15sp"
                    android:inputType="phone"
                    android:background="@null"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveFriend"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="Save Friend"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#5A189A"
                app:cornerRadius="28dp"
                app:icon="@android:drawable/ic_menu_add"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="#FFFFFF"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:elevation="0dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>